          "LocalOrder",
          "LocalOrderLine",
          "LocalPayment",
          "SuspendedOrder"
        ],
        "businessRules": [
          "商品数量必须为正整数",
          "支付金额需与应收或退款方向匹配",
          "本地订单先落库再上传"
        ],
        "crossDomainInteractions": [
          "调用支付终端产生付款",
          "把本地订单交给订单同步领域"
        ]
      }
    },
    {
      "id": "domain:order-sync",
      "type": "domain",
      "name": "订单同步",
      "summary": "负责将客户端本地 Pending/Failed 订单上传到 API，并在后端落库、生成凭证扣减和返回接收结果。该领域也支撑同步中心的单条重试和全部重试。",
      "tags": [
        "订单",
        "同步",
        "重试"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "OrderSyncRequest",
          "OrderSyncResponse",
          "PendingUpload",
          "VoucherRedemption"
        ],
        "businessRules": [
          "非零实收订单必须有付款",
          "设备必须授权到对应门店",
          "Syncing 状态不被强制重试"
        ],
        "crossDomainInteractions": [
          "读取订单结账领域产生的 LocalOrder",
          "向 API 订单落库服务提交同步请求"
        ]
      }
    },
