<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.PaymentSuccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70*" MinWidth="0" />
            <ColumnDefinition Width="30*" MinWidth="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource PosSurfaceAltBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,40,48,24">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="100" Height="100" Background="{StaticResource PosAccentBrush}" CornerRadius="50">
                            <materialDesign:PackIcon Kind="CheckCircle"
                                                     Width="58"
                                                     Height="58"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{loc:Loc PaymentSuccessful}" Margin="0,20,0,4" HorizontalAlignment="Center" FontSize="32" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                        <TextBlock Text="{loc:Loc success.subtitle}" HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource PosMutedForegroundBrush}" />
                    </StackPanel>

                    <Border Margin="0,24,0,0" Padding="24" Background="White" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="50*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc success.totalPaid}" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock Text="{Binding TotalAmountPaid, StringFormat={}{0:C2}}" Margin="0,4,0,0" FontSize="40" FontWeight="Black" />
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Margin="24,0" Background="{StaticResource PosBorderBrush}" />

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Loc success.transactionId}" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock Text="{Binding TransactionIdDisplay}" Margin="0,4,0,0" FontSize="16" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                                <TextBlock Text="{loc:Loc Time}" Margin="0,8,0,0" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock Text="{Binding SoldAtDisplay}" Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource PosTextBrush}" />
                                <TextBlock Text="{loc:Loc Terminal}" Margin="0,8,0,0" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock FontSize="12" Foreground="{StaticResource PosTextBrush}">
                                    <Run Text="{Binding StoreCode, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding DeviceCode, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding CashierName, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,16,0,0" Padding="16,12" Background="{StaticResource PosScreenBackgroundBrush}" BorderBrush="{StaticResource PosBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CloudUpload" Width="18" Height="18" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc success.syncQueued}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PosTextBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,24,0,0">
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cellphone" Width="18" Height="18" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc success.digitalReceipt}" VerticalAlignment="Center" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50*" />
                                <ColumnDefinition Width="50*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0" Padding="16" Background="{StaticResource PosScreenBackgroundBrush}" BorderBrush="{StaticResource PosBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc success.email}" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" Margin="0,0,0,8" />
                                    <TextBox Text="customer@example.com" Height="38" IsReadOnly="True" Style="{StaticResource PosSearchTextBoxStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="6,0,0,0" Padding="16" Background="{StaticResource PosScreenBackgroundBrush}" BorderBrush="{StaticResource PosBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc success.sms}" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" Margin="0,0,0,8" />
                                    <TextBox Text="+1 (555) 000-0000" Height="38" IsReadOnly="True" Style="{StaticResource PosSearchTextBoxStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1" Background="#FFE7E8EB">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="16,16,16,8" Padding="20" Background="White" CornerRadius="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Receipt" Width="18" Height="18" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc success.receiptPreview}" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding ReceiptLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="28" Margin="0,0,10,0" Background="#1A0056D2" CornerRadius="6">
                                            <TextBlock Text="{Binding QuantityDisplay, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PosPrimaryBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding LookupCode}" FontSize="9" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Black" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Payments}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}">
                                                <Run Text="{Binding MethodLabel, Mode=OneWay}" />
                                                <Run Text="{Binding DisplayReference, Mode=OneWay, StringFormat={}  {0}}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding CardSummary}" FontSize="9" Foreground="{StaticResource PosMutedForegroundBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ReceiptText}" FontSize="8" Foreground="{StaticResource PosMutedForegroundBrush}" TextWrapping="Wrap" FontFamily="Consolas" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat={}{0:C2}}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Margin="0,12" Background="{StaticResource PosBorderBrush}" />

                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="{loc:Loc Subtotal}" FontSize="12" Foreground="{StaticResource PosMutedForegroundBrush}" />
                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="12" FontWeight="SemiBold" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="{loc:Loc Discount}" FontSize="12" Foreground="{StaticResource PosMutedForegroundBrush}" />
                            <TextBlock Text="{Binding DiscountTotal, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="12" FontWeight="SemiBold" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Payments}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding MethodLabel}" FontSize="11" FontWeight="Bold" />
                                            <TextBlock Text="{Binding DisplayReference, Mode=OneWay}" FontSize="9" Foreground="{StaticResource PosMutedForegroundBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CardSummary}" FontSize="9" Foreground="{StaticResource PosMutedForegroundBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Amount, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="11" FontWeight="Bold" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Padding="12,10" Background="{StaticResource PosScreenBackgroundBrush}" CornerRadius="8">
                            <DockPanel>
                                <TextBlock Text="{loc:Loc Total}" VerticalAlignment="Center" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                                <TextBlock Text="{Binding TotalAmountPaid, StringFormat={}{0:C2}}" DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="20" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Button Grid.Row="1" Height="48" Margin="16,4,16,8" Command="{Binding PrintReceiptCommand}" Style="{StaticResource PosSecondaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Printer" Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource PosPrimaryBrush}" />
                    <TextBlock Text="{loc:Loc success.printReceipt}" FontSize="14" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Button Grid.Row="2" Height="56" Margin="16,0,16,16" Command="{Binding NewTransactionCommand}" Style="{StaticResource PosPrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cart" Width="22" Height="22" Margin="0,0,10,0" Foreground="White" />
                    <TextBlock Text="{loc:Loc success.newTransaction}" FontSize="16" FontWeight="Black" Foreground="White" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
