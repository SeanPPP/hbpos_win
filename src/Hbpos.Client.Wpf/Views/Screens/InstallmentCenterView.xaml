<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.InstallmentCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding BackToPaymentCommand}" Style="{StaticResource PosSecondaryButtonStyle}" MinHeight="38" Padding="14,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding BackToPaymentText}" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource PosSecondaryButtonStyle}" MinHeight="38" Padding="14,0" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Sync" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding LoadText}" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding PageTitleText}" Margin="0,16,0,0" FontSize="26" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                <TextBlock Text="{Binding CurrentOrderSummaryText}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource PosMutedForegroundBrush}" />
                <DockPanel Margin="0,14,0,0">
                    <Button DockPanel.Dock="Right" Command="{Binding SearchCommand}" Style="{StaticResource PosSecondaryButtonStyle}" MinHeight="40" Padding="16,0" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="搜索" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="{Binding SearchTextLabel}" Height="42" Style="{StaticResource PosSearchTextBoxStyle}" />
                </DockPanel>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,18,0,0" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="54" BorderThickness="0" GridLinesVisibility="None" HeadersVisibility="Column" Style="{StaticResource PosCartDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="分期单号" Binding="{Binding OrderNumber}" Width="150" />
                        <DataGridTextColumn Header="顾客" Binding="{Binding CustomerName}" Width="*" />
                        <DataGridTextColumn Header="电话" Binding="{Binding CustomerPhone}" Width="120" />
                        <DataGridTextColumn Header="总额" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="100" />
                        <DataGridTextColumn Header="已付" Binding="{Binding PaidAmount, StringFormat={}{0:C2}}" Width="100" />
                        <DataGridTextColumn Header="欠款" Binding="{Binding OutstandingAmount, StringFormat={}{0:C2}}" Width="100" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="终端" Binding="{Binding DeviceCode}" Width="90" />
                        <DataGridTextColumn Header="更新" Binding="{Binding UpdatedAt, StringFormat={}{0:g}}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="2" Margin="0,14,0,0" Padding="14" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding OfflineNoticeText}" Foreground="{StaticResource PosDangerBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button Command="{Binding CreateInstallmentCommand}" Style="{StaticResource PosPrimaryButtonStyle}" Height="48">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlusCircleOutline" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding CreateInstallmentText}" Foreground="White" FontWeight="Black" />
                    </StackPanel>
                </Button>

                <Border Grid.Row="1" Margin="0,14,0,0" Padding="14" Background="#FFF7F8FB" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedOrder.OrderNumber, TargetNullValue=未选择}" FontSize="18" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                        <TextBlock Text="{Binding SelectedOrder.CustomerName, TargetNullValue=请选择左侧分期单}" Margin="0,6,0,0" Foreground="{StaticResource PosMutedForegroundBrush}" />
                        <TextBlock Text="{Binding SelectedOrder.OutstandingAmount, StringFormat=欠款 {0:C2}, TargetNullValue=欠款 -}" Margin="0,12,0,0" FontSize="22" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <TextBox Text="{Binding RepaymentAmount, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}" materialDesign:HintAssist.Hint="补款金额" Height="44" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <ComboBox ItemsSource="{Binding PaymentMethodOptions}" SelectedValue="{Binding RepaymentMethod, Mode=TwoWay}" SelectedValuePath="Method" DisplayMemberPath="DisplayName" Margin="0,10,0,0" Height="42" />
                    <TextBox Text="{Binding RepaymentReference, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="流水号/券码" Margin="0,10,0,0" Height="44" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <TextBox Text="{Binding RepaymentVoucherToken, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="代金券锁定令牌" Margin="0,10,0,0" Height="44" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <Button Command="{Binding AddRepaymentCommand}" Style="{StaticResource PosSecondaryButtonStyle}" Height="44" Margin="0,10,0,0">
                        <TextBlock Text="{Binding AddRepaymentText}" FontWeight="Bold" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                    <Button Command="{Binding ConfirmPickupCommand}" Style="{StaticResource PosPrimaryButtonStyle}" Height="44">
                        <TextBlock Text="{Binding ConfirmPickupText}" Foreground="White" FontWeight="Black" />
                    </Button>
                    <Button Command="{Binding CancelWithRefundCommand}" Style="{StaticResource PosSecondaryButtonStyle}" Height="44" Margin="0,10,0,0">
                        <TextBlock Text="{Binding CancelWithRefundText}" FontWeight="Bold" />
                    </Button>
                    <TextBox Text="{Binding VoidReason, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="作废原因" Margin="0,10,0,0" Height="44" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <Button Command="{Binding VoidCancelCommand}" Style="{StaticResource PosSecondaryButtonStyle}" Height="44" Margin="0,10,0,0">
                        <TextBlock Text="{Binding VoidCancelText}" FontWeight="Bold" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
