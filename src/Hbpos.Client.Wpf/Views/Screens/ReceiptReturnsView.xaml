<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.ReceiptReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosScreenBackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ReturnPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReturnHeaderLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
        </Style>

        <Style x:Key="ReturnDangerAmountStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,18,24,14" Background="{StaticResource PosSurfaceAltBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Receipt"
                                                 Width="28"
                                                 Height="28"
                                                 Foreground="{StaticResource PosPrimaryBrush}"
                                                 Margin="0,0,10,0" />
                        <TextBlock Text="{loc:Loc returns.title}"
                                   FontSize="24"
                                   FontWeight="Black"
                                   Foreground="{StaticResource PosTextBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding OrderSummaryText}"
                               Margin="38,4,0,0"
                               Foreground="{StaticResource PosMutedForegroundBrush}"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsNoReceiptMode}"
                              Content="{loc:Loc returns.noReceipt}"
                              VerticalAlignment="Center"
                              FontWeight="Bold"
                              Margin="0,0,16,0" />
                    <Button Command="{Binding BackCommand}" Style="{StaticResource PosSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc returns.back}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,18,24,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="58" Background="#FFE2E2E6" CornerRadius="14" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="BarcodeScan"
                                             Width="24"
                                             Height="24"
                                             Foreground="{StaticResource PosPrimaryBrush}"
                                             VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="{loc:Loc returns.searchHint}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="18"
                             FontWeight="Bold"
                             VerticalContentAlignment="Center"
                             Padding="12,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LookupCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2"
                            Command="{Binding LookupCommand}"
                            Height="42"
                            MinWidth="128"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc Search}" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ReturnPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FFF3F3F7" Padding="18,14" CornerRadius="12,12,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="#FFE2E2E6" CornerRadius="8" Padding="10,4">
                                    <TextBlock FontSize="11" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}">
                                        <Run Text="{Binding OrderLines.Count, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{loc:Loc Items}" />
                                    </TextBlock>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc returns.originalReceipt}" FontSize="17" FontWeight="Black" />
                                    <TextBlock Text="{loc:Loc returns.staleWarning}"
                                               Visibility="{Binding ReturnRecordsMayBeStale, Converter={StaticResource BoolToVis}}"
                                               FontSize="11"
                                               Foreground="#FF8F4E00"
                                               FontWeight="Bold"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrderLines}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="58"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Style="{StaticResource PosCartDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="{loc:Loc Barcode}" Binding="{Binding LookupCode}" Width="112" />
                                <DataGridTextColumn Header="{loc:Loc returns.available}" Binding="{Binding AvailableRemaining, StringFormat={}{0:0.##}}" Width="84" />
                                <DataGridTextColumn Header="{loc:Loc UnitPrice}" Binding="{Binding ReturnUnitAmount, StringFormat={}{0:C2}}" Width="96" />
                                <DataGridTemplateColumn Header="" Width="58">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.AddReceiptLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Width="38"
                                                    Height="38"
                                                    Padding="0"
                                                    Style="{StaticResource PosPrimaryButtonStyle}">
                                                <materialDesign:PackIcon Kind="ArrowRight" Width="18" Height="18" Foreground="White" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ReturnPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FFFFDAD6" Padding="18,14" CornerRadius="12,12,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="White" CornerRadius="8" Padding="10,4">
                                    <TextBlock FontSize="11" FontWeight="Black">
                                        <Run Text="{Binding PendingSkuCount, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{loc:Loc Items}" />
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{loc:Loc returns.pending}" FontSize="17" FontWeight="Black" Foreground="{StaticResource PosDangerBrush}" />
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding PendingLines}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="58"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Style="{StaticResource PosCartDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="{loc:Loc Quantity}" Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Width="82" />
                                <DataGridTextColumn Header="{loc:Loc LineTotal}" Binding="{Binding NegativeSubtotal, StringFormat={}{0:C2}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ReturnDangerAmountStyle}" />
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="" Width="54">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemovePendingLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Width="36"
                                                    Height="36"
                                                    Padding="0"
                                                    Style="{StaticResource PosDangerButtonStyle}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="White" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#EFFFF7F7" Padding="18" CornerRadius="0,0,12,12">
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc returns.totalRefund}" Style="{StaticResource ReturnHeaderLabelStyle}" Foreground="{StaticResource PosDangerBrush}" />
                                    <TextBlock Text="{Binding PendingTotal, StringFormat={}{0:C2}}"
                                               FontSize="34"
                                               Style="{StaticResource ReturnDangerAmountStyle}" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ConfirmToCartCommand}"
                                        MinWidth="180"
                                        Height="56"
                                        Style="{StaticResource PosPrimaryButtonStyle}"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Cart" Width="22" Height="22" Foreground="White" Margin="0,0,10,0" />
                                        <TextBlock Text="{loc:Loc returns.addToCart}" Foreground="White" FontSize="16" FontWeight="Black" />
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PosSurfaceBrush}" Padding="24,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding ClearCommand}" Style="{StaticResource PosSecondaryButtonStyle}" MinWidth="110">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloseCircle" Width="17" Height="17" Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Loc Clear}" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
