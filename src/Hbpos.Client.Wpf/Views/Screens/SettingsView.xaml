<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosScreenBackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SettingsFieldTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource PosSearchTextBoxStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SettingsCategoryButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="SettingsActionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#FFE0E4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="#FFE1E5EC"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="{Binding ScreenTitleText}"
                           FontSize="24"
                           FontWeight="Black"
                           Foreground="{StaticResource PosTextBrush}" />
                <TextBlock Text="{Binding SettingsSubtitleText}"
                           FontSize="12"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel Visibility="{Binding IsDataMaintenanceSelected, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource SettingsActionCardStyle}" Margin="0,0,0,16">
                            <DockPanel>
                                <Border DockPanel.Dock="Left"
                                        Width="42"
                                        Height="42"
                                        Background="#FFE8F0FE"
                                        CornerRadius="8"
                                        Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="CloudDownloadOutline"
                                                             Width="24"
                                                             Height="24"
                                                             Foreground="{StaticResource PosPrimaryBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding DownloadCatalogCommand}"
                                        Style="{StaticResource PosPrimaryButtonStyle}"
                                        Height="42"
                                        MinWidth="138"
                                        Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CloudDownloadOutline" Width="18" Height="18" Margin="0,0,8,0" Foreground="White" />
                                        <TextBlock Text="{loc:Loc settings.section.dataDownload.action}" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc settings.section.dataDownload.title}"
                                               FontSize="18"
                                               FontWeight="Black"
                                               Foreground="{StaticResource PosTextBrush}" />
                                    <TextBlock Text="{loc:Loc settings.section.dataDownload.description}"
                                               FontSize="12"
                                               Foreground="{StaticResource PosMutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsActionCardStyle}">
                            <DockPanel>
                                <Border DockPanel.Dock="Left"
                                        Width="42"
                                        Height="42"
                                        Background="#FFFFF4DE"
                                        CornerRadius="8"
                                        Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="DatabaseRefreshOutline"
                                                             Width="24"
                                                             Height="24"
                                                             Foreground="#FF8F4E00"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ResetCatalogCommand}"
                                        Style="{StaticResource PosSecondaryButtonStyle}"
                                        Height="42"
                                        MinWidth="138"
                                        Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabaseRefreshOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                        <TextBlock Text="{loc:Loc settings.section.dataReset.action}" />
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc settings.section.dataReset.title}"
                                               FontSize="18"
                                               FontWeight="Black"
                                               Foreground="{StaticResource PosTextBrush}" />
                                    <TextBlock Text="{loc:Loc settings.section.dataReset.description}"
                                               FontSize="12"
                                               Foreground="{StaticResource PosMutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <Grid Visibility="{Binding IsPaymentTerminalSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SettingsActionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,18">
                                    <Border DockPanel.Dock="Left"
                                            Width="38"
                                            Height="38"
                                            Background="#FFE8F0FE"
                                            CornerRadius="8"
                                            Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="ContactlessPayment"
                                                                 Width="22"
                                                                 Height="22"
                                                                 Foreground="{StaticResource PosPrimaryBrush}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SquareTitleText}"
                                                   FontSize="18"
                                                   FontWeight="Black" />
                                        <TextBlock Text="{loc:Loc settings.square.description}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{loc:Loc settings.square.switchHelp}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource PosPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc settings.square.tokenSource}" Style="{StaticResource SettingsLabelStyle}" />
                                        <Border MinHeight="42"
                                                Background="#FFF6F8FB"
                                                BorderBrush="{StaticResource PosBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <TextBlock Text="{Binding SquareTokenStatusText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PosMutedForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <TextBlock Text="{loc:Loc settings.square.tokenHelp}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <TextBlock Text="{loc:Loc settings.square.sandbox}" Style="{StaticResource SettingsLabelStyle}" />
                                        <CheckBox IsChecked="{Binding IsSandbox, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,10,0,0">
                                            <TextBlock Text="{loc:Loc settings.square.sandbox.toggle}" FontWeight="Bold" />
                                        </CheckBox>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc settings.square.location}" Style="{StaticResource SettingsLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding SquareLocations}"
                                                  SelectedItem="{Binding SelectedSquareLocation, Mode=TwoWay}"
                                                  Style="{StaticResource SettingsComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                        <TextBlock Text="{Binding Id}" FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding LoadLocationsCommand}"
                                            Style="{StaticResource PosSecondaryButtonStyle}"
                                            MinWidth="156"
                                            Height="42"
                                            Margin="14,22,0,0"
                                            ToolTip="{loc:Loc settings.square.loadLocations.tooltip}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CloudDownloadOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                            <TextBlock Text="{loc:Loc settings.square.loadLocations}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc settings.square.device}" Style="{StaticResource SettingsLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding SquareDevices}"
                                                  SelectedItem="{Binding SelectedSquareDevice, Mode=TwoWay}"
                                                  Style="{StaticResource SettingsComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                        <TextBlock FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}">
                                                            <Run Text="{Binding Id}" />
                                                            <Run Text="  " />
                                                            <Run Text="{Binding Status}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding LoadDevicesCommand}"
                                            Style="{StaticResource PosSecondaryButtonStyle}"
                                            MinWidth="156"
                                            Height="42"
                                            Margin="14,22,0,0"
                                            ToolTip="{loc:Loc settings.square.loadDevices.tooltip}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="TabletCellphone" Width="18" Height="18" Margin="0,0,8,0" />
                                            <TextBlock Text="{loc:Loc settings.square.loadDevices}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <StackPanel Grid.Row="4" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Loc settings.square.deviceCodes}"
                                               FontSize="14"
                                               FontWeight="Black"
                                               Foreground="{StaticResource PosTextBrush}"
                                               Margin="0,0,0,8" />

                                    <Border Background="#FFFFF4DE"
                                            BorderBrush="#FFF2D3A2"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,8"
                                            Margin="0,0,0,10"
                                            Visibility="{Binding IsSquareDeviceCodesUnsupported, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding SquareDeviceCodesUnavailableText}"
                                                   FontSize="11"
                                                   Foreground="#FF8F4E00"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <Grid IsEnabled="{Binding IsSquareDeviceCodesSupported}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{loc:Loc settings.square.deviceCodeName}" Style="{StaticResource SettingsLabelStyle}" />
                                                <TextBox Text="{Binding SquareDeviceCodeNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SettingsFieldTextBoxStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Command="{Binding LoadDeviceCodesCommand}"
                                                    Style="{StaticResource PosSecondaryButtonStyle}"
                                                    MinWidth="132"
                                                    Height="42"
                                                    Margin="12,22,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ViewListOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="{loc:Loc settings.square.loadDeviceCodes}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Command="{Binding CreateDeviceCodeCommand}"
                                                    Style="{StaticResource PosSecondaryButtonStyle}"
                                                    MinWidth="140"
                                                    Height="42"
                                                    Margin="12,22,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="PlusCircleOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="{loc:Loc settings.square.createDeviceCode}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{loc:Loc settings.square.deviceCodeList}" Style="{StaticResource SettingsLabelStyle}" />
                                                <ComboBox ItemsSource="{Binding SquareDeviceCodes}"
                                                          SelectedItem="{Binding SelectedSquareDeviceCode, Mode=TwoWay}"
                                                          Style="{StaticResource SettingsComboBoxStyle}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                                <TextBlock FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}">
                                                                    <Run Text="{Binding Code}" />
                                                                    <Run Text="  " />
                                                                    <Run Text="{Binding Status}" />
                                                                    <Run Text="  " />
                                                                    <Run Text="{Binding DeviceId}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Command="{Binding RefreshDeviceCodeStatusCommand}"
                                                    Style="{StaticResource PosSecondaryButtonStyle}"
                                                    MinWidth="150"
                                                    Height="42"
                                                    Margin="12,22,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="{loc:Loc settings.square.refreshDeviceCode}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Border Grid.Row="2"
                                                Background="#FFF6F8FB"
                                                BorderBrush="{StaticResource PosBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <TextBlock Text="{loc:Loc settings.square.deviceCodesHelp}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource PosMutedForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Loc settings.square.timeoutSeconds}" Style="{StaticResource SettingsLabelStyle}" />
                                    <TextBox Text="{Binding TimeoutSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsFieldTextBoxStyle}"
                                             Width="180"
                                             HorizontalAlignment="Left" />
                                </StackPanel>

                                <Button Grid.Row="6"
                                        Command="{Binding SaveSquareCommand}"
                                        Style="{StaticResource PosPrimaryButtonStyle}"
                                        Height="46"
                                        HorizontalAlignment="Left"
                                        MinWidth="170">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" Foreground="White" />
                                        <TextBlock Text="{loc:Loc settings.square.save}" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource SettingsActionCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,18">
                                    <Border DockPanel.Dock="Left"
                                            Width="38"
                                            Height="38"
                                            Background="#FFFFF4DE"
                                            CornerRadius="8"
                                            Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="LanConnect"
                                                                 Width="22"
                                                                 Height="22"
                                                                 Foreground="#FF8F4E00"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LinklyTitleText}"
                                                   FontSize="18"
                                                   FontWeight="Black" />
                                        <TextBlock Text="{loc:Loc settings.linkly.description}"
                                                   FontSize="11"
                                                   Foreground="#FF8F4E00"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="{loc:Loc settings.linkly.host}" Style="{StaticResource SettingsLabelStyle}" />
                                <TextBox Text="{Binding LinklyHostText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsFieldTextBoxStyle}"
                                         Margin="0,0,0,14" />

                                <TextBlock Text="{loc:Loc settings.linkly.port}" Style="{StaticResource SettingsLabelStyle}" />
                                <TextBox Text="{Binding LinklyPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsFieldTextBoxStyle}"
                                         Margin="0,0,0,18" />

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding TestLinklyCommand}"
                                            Style="{StaticResource PosSecondaryButtonStyle}"
                                            Height="42"
                                            MinWidth="138"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LanConnect" Width="18" Height="18" Margin="0,0,8,0" />
                                            <TextBlock Text="{loc:Loc settings.linkly.test}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SaveLinklyCommand}"
                                            Style="{StaticResource PosPrimaryButtonStyle}"
                                            Height="42"
                                            MinWidth="138">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" Foreground="White" />
                                            <TextBlock Text="{loc:Loc settings.linkly.enable}" Foreground="White" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border Background="#FFF6F8FB"
                                        BorderBrush="#FFE0E4EC"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,12,0,0">
                                    <TextBlock Text="{Binding LinklyTestStatusMessage}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PosMutedForegroundBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Visibility="{Binding IsDeviceRegistrationSelected, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource SettingsActionCardStyle}">
                            <DockPanel>
                                <Border DockPanel.Dock="Left"
                                        Width="42"
                                        Height="42"
                                        Background="#FFE8F0FE"
                                        CornerRadius="8"
                                        Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="CashRegister"
                                                             Width="24"
                                                             Height="24"
                                                             Foreground="{StaticResource PosPrimaryBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ReregisterDeviceCommand}"
                                        Style="{StaticResource PosPrimaryButtonStyle}"
                                        Height="42"
                                        MinWidth="154"
                                        Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountSwitch" Width="18" Height="18" Margin="0,0,8,0" Foreground="White" />
                                        <TextBlock Text="{loc:Loc settings.deviceRegistration.action}" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="{Binding DeviceRegistrationTitleText}"
                                               FontSize="18"
                                               FontWeight="Black"
                                               Foreground="{StaticResource PosTextBrush}" />
                                    <TextBlock Text="{loc:Loc settings.deviceRegistration.description}"
                                               FontSize="12"
                                               Foreground="{StaticResource PosMutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Background="{StaticResource PosSurfaceBrush}"
                    BorderBrush="#FFE0E4EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="{loc:Loc settings.category.title}"
                               FontSize="13"
                               FontWeight="Black"
                               Foreground="{StaticResource PosTextBrush}"
                               Margin="2,0,0,12" />

                    <Button Command="{Binding SelectDataMaintenanceCommand}"
                            Style="{StaticResource SettingsCategoryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseSyncOutline" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding DataMaintenanceTitleText}" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectPaymentTerminalCommand}"
                            Style="{StaticResource SettingsCategoryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContactlessPayment" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="{loc:Loc settings.category.paymentTerminal}" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectDeviceRegistrationCommand}"
                            Style="{StaticResource SettingsCategoryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashRegister" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding DeviceRegistrationTitleText}" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFAFAFA"
                BorderBrush="#FFE1E5EC"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="InformationOutline"
                                         Width="16"
                                         Height="16"
                                         Foreground="{StaticResource PosMutedForegroundBrush}"
                                         Margin="0,0,8,0" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           TextTrimming="CharacterEllipsis" />
                <ProgressBar Width="90"
                             Height="4"
                             Margin="14,0,0,0"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
