<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.CustomerDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosScreenBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="66*" MinWidth="0" />
                <ColumnDefinition Width="34*" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="126" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc ItemDescription}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="{loc:Loc Quantity}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{loc:Loc Price}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="{loc:Loc Total}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Lines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14" Margin="0,0,0,8" Background="{StaticResource PosSurfaceAltBrush}" BorderBrush="#FFE4E7EC" BorderThickness="1" CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="116" />
                                                <ColumnDefinition Width="126" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LookupCode}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,4" Background="#1A0056D2" CornerRadius="12">
                                                <TextBlock Text="{Binding QuantityDisplay, Mode=OneWay}" Foreground="{StaticResource PosPrimaryBrush}" FontWeight="Black" />
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat={}{0:C2}}" FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Black" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="18,0,0,0" CornerRadius="18" Background="#243B2E" ClipToBounds="True">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#315C3D" Offset="0" />
                                <GradientStop Color="#D6452E" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Opacity="0.18" Fill="#FF000000" />
                    <StackPanel Margin="48,44">
                        <Border Background="{StaticResource PosWarningBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc customer.promotionTitle}" Foreground="#3A2400" FontSize="12" FontWeight="Black" />
                        </Border>
                        <TextBlock Text="{loc:Loc customer.promotionSubtitle}" Margin="0,18,0,8" Foreground="White" FontSize="34" FontWeight="Black" TextWrapping="Wrap" />
                        <TextBlock Text="{loc:Loc customer.promotionBody}" Foreground="#FFF2F4F7" FontSize="16" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,28,28" Background="#33000000" CornerRadius="16" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Monitor" Width="22" Height="22" Foreground="White" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding TerminalName}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Margin="0,0,40,0">
                    <TextBlock Text="{loc:Loc Subtotal}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" />
                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C2}}" FontSize="24" FontWeight="Black" />
                </StackPanel>
                <StackPanel Margin="0,0,40,0">
                    <TextBlock Text="{loc:Loc Tax}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" />
                    <TextBlock Text="{Binding TaxAmount, StringFormat={}{0:C2}}" FontSize="24" FontWeight="Black" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Savings}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" FontWeight="Bold" />
                    <TextBlock Text="{Binding SavingsAmount, StringFormat=-{0:C2}}" FontSize="24" FontWeight="Black" Foreground="{StaticResource PosDangerBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,32,0" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc customer.totalToPay}" Foreground="{StaticResource PosPrimaryBrush}" FontSize="12" FontWeight="Black" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding TotalToPay, StringFormat={}{0:C2}}" Foreground="{StaticResource PosPrimaryBrush}" FontSize="58" FontWeight="Black" HorizontalAlignment="Right" />
            </StackPanel>

            <Border Grid.Column="2" Background="{StaticResource PosPrimaryBrush}" CornerRadius="12" Padding="18" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{loc:Loc customer.readyForPayment}" Foreground="White" FontSize="16" FontWeight="Black" />
                    <TextBlock Text="{loc:Loc customer.insertOrTap}" Foreground="#FFD9E7FF" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
