<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.SpecialProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Hbpos.Client.Wpf.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosScreenBackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:StringNullOrWhiteSpaceToVisibilityConverter x:Key="StringHasValueToVis" />
        <converters:StringNullOrWhiteSpaceToVisibilityConverter x:Key="StringIsEmptyToVis" Invert="True" />

        <Style x:Key="TouchIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>

        <Style x:Key="SpecialProductCardStyle" TargetType="Border">
            <Setter Property="Width" Value="226" />
            <Setter Property="MinHeight" Value="316" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#FFE0E4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PosScreenBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PosSurfaceBrush}" BorderBrush="#FFE1E5EC" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource PosSecondaryButtonStyle}"
                        MinHeight="64"
                        Padding="18,0"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding BackText}" FontWeight="Black" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleText}" FontSize="24" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                    <TextBlock Text="{Binding SubtitleText}" FontSize="12" Foreground="{StaticResource PosMutedForegroundBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FFE8F0FE" CornerRadius="18" Padding="14,8" Margin="0,0,10,0">
                        <TextBlock Text="{Binding OnlineStateText}" FontSize="12" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                    </Border>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource PosSecondaryButtonStyle}"
                            MinHeight="64"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RefreshText}" FontWeight="Black" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="20,16,20,8" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE0E4EC" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PosSearchTextBoxStyle}"
                             Height="64"
                             FontSize="18"
                             materialDesign:HintAssist.Hint="{Binding SearchPlaceholderText}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource PosSecondaryButtonStyle}"
                            MinHeight="64"
                            MinWidth="94"
                            Margin="10,0,0,0">
                        <TextBlock Text="{Binding ClearSearchText}" FontWeight="Black" />
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource PosPrimaryButtonStyle}"
                            MinHeight="64"
                            MinWidth="132"
                            Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SearchButtonText}" Foreground="White" FontWeight="Black" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="{Binding SearchResultsText}" FontSize="11" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" Margin="2,0,0,8" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="116">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="238" Height="104" Margin="0,0,10,0" Padding="8" Background="#FFF8FAFD" BorderBrush="#FFE0E4EC" BorderThickness="1" CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#FFE8F0FE" CornerRadius="6">
                                                <Grid>
                                                    <materialDesign:PackIcon Kind="Image" Width="26" Height="26" Foreground="{StaticResource PosPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Image Source="{Binding ProductImage}" Stretch="UniformToFill" Visibility="{Binding ProductImage, Converter={StaticResource StringHasValueToVis}}" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Black" TextWrapping="Wrap" MaxHeight="38" />
                                                <TextBlock Text="{Binding LookupCode}" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding RetailPrice, StringFormat={}{0:C2}}" FontSize="15" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Command="{Binding DataContext.AddSpecialProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PosPrimaryButtonStyle}"
                                                    MinWidth="64"
                                                    MinHeight="64"
                                                    Padding="0"
                                                    ToolTip="{Binding DataContext.AddText, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                <materialDesign:PackIcon Kind="Plus" Width="24" Height="24" Foreground="White" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,4,20,10">
            <Border Visibility="{Binding IsSpecialListEmpty, Converter={StaticResource BoolToVis}}"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFE0E4EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="30">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Star" Width="52" Height="52" Foreground="{StaticResource PosAccentBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EmptyText}" FontSize="18" FontWeight="Black" TextAlignment="Center" Margin="0,14,0,0" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SpecialItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SpecialProductCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="176" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0"
                                            Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PosSearchSegmentButtonStyle}"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch">
                                        <Border Background="#FFE8F0FE" CornerRadius="8,8,0,0" ClipToBounds="True">
                                            <Grid>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Image" Width="42" Height="42" Foreground="{StaticResource PosPrimaryBrush}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                                <Image Source="{Binding ProductImage}" Stretch="UniformToFill" Visibility="{Binding ProductImage, Converter={StaticResource StringHasValueToVis}}" />
                                                <Border VerticalAlignment="Bottom" Background="#CC111827" Padding="10,6">
                                                    <TextBlock Text="{Binding DataContext.TapToAddText, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Foreground="White" FontSize="12" FontWeight="Black" TextAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <StackPanel Grid.Row="1" Margin="12,10,12,8">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="Black" TextWrapping="Wrap" MaxHeight="44" />
                                        <TextBlock Text="{Binding ItemNumber}" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding LookupCode}" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RetailPrice, StringFormat={}{0:C2}}" FontSize="22" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,8,0,0" />
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="8,0,8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TouchIconButtonStyle}"
                                                ToolTip="{Binding DataContext.MoveUpText, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <materialDesign:PackIcon Kind="ArrowUp" Width="22" Height="22" />
                                        </Button>
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TouchIconButtonStyle}"
                                                ToolTip="{Binding DataContext.MoveDownText, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <materialDesign:PackIcon Kind="ArrowDown" Width="22" Height="22" />
                                        </Button>
                                        <Button Grid.Column="2"
                                                Command="{Binding DataContext.RemoveSpecialProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TouchIconButtonStyle}"
                                                Background="#FFFFEEF0"
                                                BorderBrush="#FFFFCCD2"
                                                Foreground="{StaticResource PosDangerBrush}"
                                                ToolTip="{Binding DataContext.RemoveText, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="22" Height="22" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource PosSurfaceBrush}" BorderBrush="#FFE1E5EC" BorderThickness="0,1,0,0" Padding="20,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
