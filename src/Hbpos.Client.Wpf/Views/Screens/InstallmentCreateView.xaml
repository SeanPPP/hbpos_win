<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.InstallmentCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Button Command="{Binding BackToCenterCommand}" Style="{StaticResource PosSecondaryButtonStyle}" HorizontalAlignment="Left" MinHeight="38" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding BackToCenterText}" FontWeight="Bold" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding PageTitleText}" Margin="0,16,0,0" FontSize="26" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,18,0,0" Padding="18" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="顾客姓名" Height="46" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <TextBox Grid.Column="2" Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="顾客电话" Height="46" Style="{StaticResource PosSearchTextBoxStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,14,0,0" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding CartLines}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="48" BorderThickness="0" GridLinesVisibility="None" HeadersVisibility="Column" Style="{StaticResource PosCartDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="商品" Binding="{Binding DisplayName}" Width="*" />
                        <DataGridTextColumn Header="条码" Binding="{Binding LookupCode}" Width="120" />
                        <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="80" />
                        <DataGridTextColumn Header="单价" Binding="{Binding UnitPrice, StringFormat={}{0:C2}}" Width="100" />
                        <DataGridTextColumn Header="折扣" Binding="{Binding DiscountAmount, StringFormat={}{0:C2}}" Width="100" />
                        <DataGridTextColumn Header="行金额" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Margin="0,14,0,0" Padding="14" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PosMutedForegroundBrush}" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="White" BorderBrush="#FFE7E8EB" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="订单总额" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PosMutedForegroundBrush}" />
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C2}}" Margin="0,8,0,0" FontSize="30" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                    <TextBlock Text="{Binding FinancedAmount, StringFormat=待补 {0:C2}}" Margin="0,8,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PosPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <TextBox Text="{Binding DownPaymentAmount, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}" materialDesign:HintAssist.Hint="首付金额" Height="46" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <ComboBox ItemsSource="{Binding PaymentMethodOptions}" SelectedValue="{Binding DownPaymentMethod, Mode=TwoWay}" SelectedValuePath="Method" DisplayMemberPath="DisplayName" Margin="0,10,0,0" Height="42" />
                    <TextBox Text="{Binding DownPaymentReference, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="流水号/券码" Margin="0,10,0,0" Height="46" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <TextBox Text="{Binding VoucherReservationToken, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="代金券锁定令牌" Margin="0,10,0,0" Height="46" Style="{StaticResource PosSearchTextBoxStyle}" />
                    <TextBlock Text="{Binding DownPaymentStatusText}" Margin="0,12,0,0" Foreground="{StaticResource PosMutedForegroundBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <TextBox Grid.Row="2" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="备注" Margin="0,20,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Style="{StaticResource PosSearchTextBoxStyle}" />

                <Button Grid.Row="3" Command="{Binding SubmitCommand}" Style="{StaticResource PosPrimaryButtonStyle}" Height="48">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SubmitText}" Foreground="White" FontWeight="Black" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
