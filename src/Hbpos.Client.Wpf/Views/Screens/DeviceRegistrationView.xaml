<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.DeviceRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Background="{StaticResource PosScreenBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="620"
                Background="White"
                BorderBrush="#FFE0E3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="28"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.12" />
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                    <Border Width="42" Height="42" Background="{StaticResource PosPrimaryBrush}" CornerRadius="8" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="CashRegister"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TitleText}"
                                   FontSize="22"
                                   FontWeight="Black"
                                   Foreground="{StaticResource PosTextBrush}" />
                        <TextBlock Text="{loc:Loc AppName}"
                                   FontSize="12"
                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{loc:Loc deviceRegistration.store}"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding Stores}"
                          SelectedItem="{Binding SelectedStore, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Height="42"
                          FontSize="15"
                          Margin="0,0,0,16" />

                <TextBlock Text="{loc:Loc deviceRegistration.hardwareId}"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding HardwareId}"
                         IsReadOnly="True"
                         Height="42"
                         FontSize="12"
                         TextWrapping="NoWrap"
                         Margin="0,0,0,16" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc deviceRegistration.deviceCode}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding DeviceCode}"
                                 IsReadOnly="True"
                                 Height="42"
                                 FontSize="14" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="{loc:Loc common.status}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                   Margin="0,0,0,6" />
                        <Border Height="42"
                                Background="#FFFFF7E8"
                                BorderBrush="#FFFFD59B"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,0">
                            <TextBlock Text="{Binding StatusMessage}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#FF8F4E00"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Command="{Binding RegisterCommand}"
                            Height="46"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="PlusCircle" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding RegisterButtonText}" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding VerifyCommand}"
                            Height="46"
                            Style="{StaticResource PosSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Sync" Width="18" Height="18" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc deviceRegistration.verify}" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                            Height="46"
                            Style="{StaticResource PosSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc shell.backToPos}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
