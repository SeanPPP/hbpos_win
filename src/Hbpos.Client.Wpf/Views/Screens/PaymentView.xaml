<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:orders="clr-namespace:Hbpos.Contracts.Orders;assembly=Hbpos.Contracts"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <UserControl.Resources>
        <Style x:Key="ZeroPricePaymentCartRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFE2E2E6" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasZeroUnitPrice}" Value="True">
                    <Setter Property="Background" Value="#FFFFEEF0" />
                    <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosDangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReturnLine}" Value="True">
                    <Setter Property="Background" Value="#FFFFEEF0" />
                    <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosDangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ZeroPricePaymentAmountTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasZeroUnitPrice}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
                    <Setter Property="FontWeight" Value="Black" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReturnLine}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
                    <Setter Property="FontWeight" Value="Black" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaymentKeypadNumberTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="44" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="PaymentKeypadFunctionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PaymentKeypadNumberTextStyle}">
            <Setter Property="FontSize" Value="44" />
        </Style>

        <Style x:Key="CashMethodButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPaymentMethodButtonStyle}">
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFF3E0" />
            <Setter Property="BorderBrush" Value="{StaticResource PosAccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PosAccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCashSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PosAccentBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosAccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardMethodButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPaymentMethodButtonStyle}">
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFE8F0FE" />
            <Setter Property="BorderBrush" Value="{StaticResource PosPrimaryBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PosPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCardSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PosPrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosPrimaryBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VoucherMethodButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPaymentMethodButtonStyle}">
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFEAF7EF" />
            <Setter Property="BorderBrush" Value="{StaticResource PosSuccessBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PosSuccessBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVoucherSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PosSuccessBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosSuccessBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*" MinWidth="0" />
            <ColumnDefinition Width="42*" MinWidth="0" />
            <ColumnDefinition Width="28*" MinWidth="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource PosScreenBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="20,16" Background="{StaticResource PosScreenBackgroundBrush}">
                <StackPanel>
                    <Button Command="{Binding BackToPosCommand}"
                            Style="{StaticResource PosSecondaryButtonStyle}"
                            HorizontalAlignment="Left"
                            MinHeight="38"
                            Padding="14,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc shell.backToPos}" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Padding="8,3" Background="#1A0056D2" CornerRadius="4">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource PosPrimaryBrush}">
                                <Run Text="{Binding CartLines.Count, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{loc:Loc Items}" />
                            </TextBlock>
                        </Border>
                        <TextBlock Text="{Binding OrderSummaryText}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding CartLines}"
                      IsReadOnly="True"
                      RowBackground="White"
                      AlternatingRowBackground="{StaticResource PosSurfaceAltBrush}"
                      RowHeight="54"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      RowStyle="{StaticResource ZeroPricePaymentCartRowStyle}"
                      Style="{StaticResource PosCartDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="{loc:Loc Quantity}" Binding="{Binding SignedQuantity, StringFormat={}{0:0.##}}" Width="70" />
                    <DataGridTextColumn Header="{loc:Loc Total}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="104">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ZeroPricePaymentAmountTextStyle}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Padding="20,16" Background="#E8FFFFFF" BorderBrush="#FFE2E2E6" BorderThickness="0,1,0,0">
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="PaymentSummaryAmountColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc Subtotal}" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:C2}}" HorizontalAlignment="Right" TextAlignment="Right" FontSize="14" FontWeight="SemiBold" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="PaymentSummaryAmountColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc Discount}" FontSize="11" Foreground="{StaticResource PosMutedForegroundBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding DiscountAmount, StringFormat={}{0:C2}}" HorizontalAlignment="Right" TextAlignment="Right" FontSize="14" FontWeight="SemiBold" />
                    </Grid>

                    <Border Grid.Row="2" Height="1" Background="{StaticResource PosBorderBrush}" Margin="0,0,0,8" />

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="PaymentSummaryAmountColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc AmountDue}" VerticalAlignment="Center" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" HorizontalAlignment="Right" TextAlignment="Right" FontSize="28" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource PosSurfaceAltBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,16,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Margin="0,0,4,0" Padding="16" Background="#FFE8F0FE" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="{Binding RemainingAmountText}" FontSize="9" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                        <TextBlock Text="{Binding RemainingAmount, StringFormat={}{0:C2}}" FontSize="28" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="4,0,0,0" Padding="16" Background="#FFFFDCC2" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="{Binding ChangeDueText}" FontSize="9" FontWeight="Black" Foreground="#8F4E00" />
                        <TextBlock Text="{Binding ChangeDue, StringFormat={}{0:C2}}" FontSize="28" FontWeight="Black" Foreground="#623400" HorizontalAlignment="Right" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="16,4,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border MinHeight="62"
                        Padding="14,8"
                        Background="#FFE2E2E6"
                        BorderBrush="{StaticResource PosAccentBrush}"
                        BorderThickness="0,0,0,3"
                        CornerRadius="8"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentTenderTextLabel}"
                                   FontSize="9"
                                   FontWeight="Black"
                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TenderAmountText}"
                                   FontSize="44"
                                   FontWeight="Black"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Button Grid.Column="1"
                        Command="{Binding NumberInputCommand}"
                        CommandParameter="Back"
                        Style="{StaticResource PosNumberButtonStyle}"
                        Width="64"
                        MinHeight="62"
                        Margin="8,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="BackspaceOutline"
                                             Width="30"
                                             Height="30"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </Grid>

            <DockPanel Grid.Row="2" Margin="16,0,16,16" LastChildFill="True">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTenderEntryVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>

                <ItemsControl DockPanel.Dock="Right" ItemsSource="{Binding QuickCashAmounts}" Width="96" Margin="8,0,0,0">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCashSelected}" Value="True" />
                                        <Condition Binding="{Binding IsQuickCashVisible}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="{Binding NoteColorKey}"
                                    BorderBrush="{Binding NoteColorKey}"
                                    Foreground="{Binding ForegroundColorKey}"
                                    Command="{Binding DataContext.QuickCashCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource PosQuickAmountButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Cash"
                                                             Width="16"
                                                             Height="16"
                                                             Margin="0,0,6,0"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               FontWeight="Black"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <UniformGrid Columns="3" Margin="0">
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="1" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="1" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="2" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="2" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="3" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="3" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="4" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="4" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="5" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="5" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="6" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="6" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="7" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="7" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="8" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="8" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="9" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="9" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="." Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="." Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}" CommandParameter="0" Style="{StaticResource PosNumberButtonStyle}">
                        <TextBlock Text="0" Style="{StaticResource PaymentKeypadNumberTextStyle}" />
                    </Button>
                    <Button Command="{Binding NumberInputCommand}"
                            CommandParameter="Clear"
                            Style="{StaticResource PosNumberButtonStyle}"
                            Background="#FFFFDAD6"
                            BorderBrush="#FFFFB4AB"
                            Foreground="#FFBA1A1A">
                        <TextBlock Text="{loc:Loc Clear}" Style="{StaticResource PaymentKeypadFunctionTextStyle}" />
                    </Button>
                </UniformGrid>
            </DockPanel>

            <Grid Grid.Row="3" Margin="16,0,16,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.8*" />
                </Grid.ColumnDefinitions>
                <Button Command="{Binding CancelCommand}" Height="50" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCancelPaymentVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="{Binding CancelText}" FontWeight="Bold" HorizontalAlignment="Center" />
                </Button>
                <Button Command="{Binding ConfirmPaymentCommand}"
                        Height="50">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PosPrimaryButtonStyle}">
                            <Setter Property="Grid.Column" Value="0" />
                            <Setter Property="Grid.ColumnSpan" Value="2" />
                            <Setter Property="Margin" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCancelPaymentVisible}" Value="True">
                                    <Setter Property="Grid.Column" Value="1" />
                                    <Setter Property="Grid.ColumnSpan" Value="1" />
                                    <Setter Property="Margin" Value="8,0,0,0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="22" Height="22" Foreground="White" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding ConfirmPaymentText}" Foreground="White" FontSize="16" FontWeight="Black" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Column="2" Background="#FFE7E8EB">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding PaymentMethodText}" Margin="24,24,24,8" FontSize="11" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPaymentMethodSelectionVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel Grid.Row="1" Margin="24,0,24,8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPaymentMethodSelectionVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Button Command="{Binding SelectCashCommand}" Style="{StaticResource CashMethodButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" Margin="0,0,14,0" Background="#33FFFFFF" CornerRadius="10">
                            <materialDesign:PackIcon Kind="Cash" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Border>
                        <TextBlock Text="{Binding CashMethodText}" VerticalAlignment="Center" FontSize="17" FontWeight="Black" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SelectCardCommand}" Style="{StaticResource CardMethodButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" Margin="0,0,14,0" Background="#33FFFFFF" CornerRadius="10">
                            <materialDesign:PackIcon Kind="CreditCard" Width="28" Height="28" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CardMethodText}" VerticalAlignment="Center" FontSize="17" FontWeight="Black" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SelectVoucherCommand}" Style="{StaticResource VoucherMethodButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" Margin="0,0,14,0" Background="#33FFFFFF" CornerRadius="10">
                            <materialDesign:PackIcon Kind="TicketPercent" Width="28" Height="28" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding VoucherMethodText}" VerticalAlignment="Center" FontSize="17" FontWeight="Black" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowInstallmentCenterCommand}"
                        Margin="0,8,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CardMethodButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstallmentEntryVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" Margin="0,0,14,0" Background="#33FFFFFF" CornerRadius="10">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="28" Height="28" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding InstallmentMethodText}" VerticalAlignment="Center" FontSize="17" FontWeight="Black" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>
                <TextBox Text="{Binding VoucherCodeText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc payment.voucher.code}"
                         Height="40"
                         Margin="0,8,0,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource PosSearchTextBoxStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVoucherCodeEntryVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>

            <Border Grid.Row="2" Margin="24,8,24,8" Padding="14" Background="White" BorderBrush="#FFE2E2E6" BorderThickness="1" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding AppliedTendersText}" FontSize="10" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}" Margin="0,0,0,10" />
                    <Grid Grid.Row="1">
                        <TextBlock Text="{Binding NoTendersText}" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaymentTenders.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PaymentTenders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                Background="#FFFAFAFA"
                                                BorderBrush="#FFE7E8EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.RemoveTenderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="38" Height="38" CornerRadius="9" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFFFF3E0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Card}">
                                                                    <Setter Property="Background" Value="#FFE8F0FE" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Voucher}">
                                                                    <Setter Property="Background" Value="#FFEAF7EF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <materialDesign:PackIcon Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Kind" Value="Cash" />
                                                                <Setter Property="Foreground" Value="{StaticResource PosAccentBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Card}">
                                                                        <Setter Property="Kind" Value="CreditCard" />
                                                                        <Setter Property="Foreground" Value="{StaticResource PosPrimaryBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Voucher}">
                                                                        <Setter Property="Kind" Value="TicketPercent" />
                                                                        <Setter Property="Foreground" Value="{StaticResource PosSuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="15" FontWeight="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{loc:Loc payment.method.cash}" />
                                                                <Setter Property="Foreground" Value="{StaticResource PosAccentBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Card}">
                                                                        <Setter Property="Text" Value="{loc:Loc payment.method.card}" />
                                                                        <Setter Property="Foreground" Value="{StaticResource PosPrimaryBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Voucher}">
                                                                        <Setter Property="Text" Value="{loc:Loc payment.method.voucher}" />
                                                                        <Setter Property="Foreground" Value="{StaticResource PosSuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding DisplayReference}" FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C2}}" VerticalAlignment="Center" FontSize="16" FontWeight="Black">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource PosAccentBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Card}">
                                                                    <Setter Property="Foreground" Value="{StaticResource PosPrimaryBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Method}" Value="{x:Static orders:PaymentMethodKind.Voucher}">
                                                                    <Setter Property="Foreground" Value="{StaticResource PosSuccessBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Grid.Column="3" Command="{Binding DataContext.RemoveTenderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Width="30" Height="30" Margin="10,0,0,0" Style="{StaticResource TitleBarButtonStyle}">
                                                    <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="24,0,24,24" Padding="14" Background="White" BorderBrush="#FFFFD59B" BorderThickness="1" CornerRadius="12" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="32" Height="32" Margin="0,0,10,0" Background="{StaticResource PosAccentBrush}" CornerRadius="16" VerticalAlignment="Top">
                        <materialDesign:PackIcon Kind="Information" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#8F4E00" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
