<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.TransactionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="HistoryFilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="0" />
            <ColumnDefinition Width="380" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PosScreenBackgroundBrush}" Padding="24,20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="{loc:Loc TransactionHistory}" FontSize="22" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="来源" Style="{StaticResource HistoryFilterLabel}" />
                            <ComboBox ItemsSource="{Binding SourceOptions}"
                                      SelectedItem="{Binding SelectedSourceOption, Mode=TwoWay}"
                                      DisplayMemberPath="Label"
                                      Height="40" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc history.dateRangeLabel}" Style="{StaticResource HistoryFilterLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding DateFromText, UpdateSourceTrigger=PropertyChanged}" Height="40" Style="{StaticResource PosSearchTextBoxStyle}" />
                                <TextBox Grid.Column="2" Text="{Binding DateToText, UpdateSourceTrigger=PropertyChanged}" Height="40" Style="{StaticResource PosSearchTextBoxStyle}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc Store}" Style="{StaticResource HistoryFilterLabel}" />
                            <TextBox Text="{Binding StoreFilterText}" IsReadOnly="True" Height="40" Style="{StaticResource PosSearchTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc Terminal}" Style="{StaticResource HistoryFilterLabel}" />
                            <TextBox Text="{Binding TerminalFilterText, UpdateSourceTrigger=PropertyChanged}" Height="40" Style="{StaticResource PosSearchTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc history.searchLabel}" Style="{StaticResource HistoryFilterLabel}" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding SearchHintText}"
                                     Height="40"
                                     Style="{StaticResource PosSearchTextBoxStyle}" />
                        </StackPanel>

                        <Button Grid.Column="5"
                                Command="{Binding LoadCommand}"
                                MinWidth="96"
                                Height="40"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource PosPrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Sync" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc common.load}" Foreground="White" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="24,0,24,0" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" />
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowBackground="White"
                          AlternatingRowBackground="#FFFAFBFF"
                          RowHeight="50"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          Style="{StaticResource PosCartDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding ShortOrderId}" Width="94" />
                        <DataGridTextColumn Header="{loc:Loc Store}" Binding="{Binding StoreCode}" Width="92" />
                        <DataGridTextColumn Header="{loc:Loc Terminal}" Binding="{Binding DeviceCode}" Width="106" />
                        <DataGridTextColumn Header="{loc:Loc Time}" Binding="{Binding SoldAtDisplay}" Width="154" />
                        <DataGridTextColumn Header="{loc:Loc Items}" Binding="{Binding LineCount}" Width="72" />
                        <DataGridTextColumn Header="{loc:Loc Amount}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="112" />
                        <DataGridTextColumn Header="{loc:Loc Payment}" Binding="{Binding PaymentSummary}" Width="108" />
                        <DataGridTextColumn Header="{loc:Loc common.status}" Binding="{Binding StatusLabel}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <DockPanel Grid.Row="2" Margin="24,14,24,18">
                <TextBlock Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center">
                    <Run Text="{loc:Loc history.showingPrefix}" />
                    <Run Text="{Binding Orders.Count, Mode=OneWay}" />
                    <Run Text=" " />
                    <Run Text="{loc:Loc history.transactions}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource PosDangerBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Grid>

        <Border Grid.Column="1" Background="#FFE7E8EB" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="2,2,0,0" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <materialDesign:PackIcon Kind="Receipt" Width="18" Height="18" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc success.receiptPreview}" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                            </StackPanel>

                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="{loc:Loc AppName}" FontSize="20" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding PreviewOrderId}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PosMutedForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding PreviewSoldAt}" FontSize="10" Foreground="{StaticResource PosMutedForegroundBrush}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <Rectangle Height="1" Fill="{StaticResource PosBorderBrush}" Margin="0,0,0,12" StrokeDashArray="4,3" Stroke="{StaticResource PosBorderBrush}" StrokeThickness="1" />

                            <ItemsControl ItemsSource="{Binding ReceiptLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" />
                                                <TextBlock FontSize="9" Foreground="{StaticResource PosMutedForegroundBrush}">
                                                    <Run Text="{Binding QuantityDisplay, Mode=OneWay}" />
                                                    <Run Text=" x " />
                                                    <Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat={}{0:C2}}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Rectangle Height="1" Fill="{StaticResource PosBorderBrush}" Margin="0,8" StrokeDashArray="4,3" Stroke="{StaticResource PosBorderBrush}" StrokeThickness="1" />

                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{loc:Loc Subtotal}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock Text="{Binding PreviewSubtotal, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="11" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc Discount}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PosMutedForegroundBrush}" />
                                <TextBlock Text="{Binding PreviewDiscount, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="11" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{loc:Loc Total}" FontSize="16" FontWeight="Black" />
                                <TextBlock Text="{Binding PreviewTotal, StringFormat={}{0:C2}}" DockPanel.Dock="Right" FontSize="18" FontWeight="Black" Foreground="{StaticResource PosPrimaryBrush}" />
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Command="{Binding ReprintCommand}" Margin="0,0,6,0" Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Printer" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc history.reprint}" Foreground="White" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding RecallSelectedCommand}" Margin="6,0,0,0" Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardTextClock" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                            <TextBlock Text="取回挂单" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
