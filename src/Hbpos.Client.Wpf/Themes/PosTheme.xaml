<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="PosColorCanvas">#FFF3F3F7</Color>
    <Color x:Key="PosColorSurface">#FFFFFFFF</Color>
    <Color x:Key="PosColorSurfaceAlt">#FFF9F9FD</Color>
    <Color x:Key="PosColorPrimary">#FF0056D2</Color>
    <Color x:Key="PosColorPrimaryDark">#FF191C1E</Color>
    <Color x:Key="PosColorAccent">#FFFF8F00</Color>
    <Color x:Key="PosColorSuccess">#FF0F9D58</Color>
    <Color x:Key="PosColorWarning">#FFFFB74D</Color>
    <Color x:Key="PosColorDanger">#FF940010</Color>
    <Color x:Key="PosColorText">#FF191C1E</Color>
    <Color x:Key="PosColorMutedText">#FF737785</Color>
    <Color x:Key="PosColorBorder">#FFC3C6D6</Color>
    <Color x:Key="PosColorHeader">#FFFFFFFF</Color>
    <Color x:Key="PosColorFooter">#FFFFFFFF</Color>

    <SolidColorBrush x:Key="PosScreenBackgroundBrush" Color="{StaticResource PosColorCanvas}" />
    <SolidColorBrush x:Key="PosSurfaceBrush" Color="{StaticResource PosColorSurface}" />
    <SolidColorBrush x:Key="PosSurfaceAltBrush" Color="{StaticResource PosColorSurfaceAlt}" />
    <SolidColorBrush x:Key="PosPrimaryBrush" Color="{StaticResource PosColorPrimary}" />
    <SolidColorBrush x:Key="PosPrimaryDarkBrush" Color="{StaticResource PosColorPrimaryDark}" />
    <SolidColorBrush x:Key="PosAccentBrush" Color="{StaticResource PosColorAccent}" />
    <SolidColorBrush x:Key="PosSuccessBrush" Color="{StaticResource PosColorSuccess}" />
    <SolidColorBrush x:Key="PosWarningBrush" Color="{StaticResource PosColorWarning}" />
    <SolidColorBrush x:Key="PosDangerBrush" Color="{StaticResource PosColorDanger}" />
    <SolidColorBrush x:Key="PosTextBrush" Color="{StaticResource PosColorText}" />
    <SolidColorBrush x:Key="PosMutedForegroundBrush" Color="{StaticResource PosColorMutedText}" />
    <SolidColorBrush x:Key="PosBorderBrush" Color="{StaticResource PosColorBorder}" />
    <SolidColorBrush x:Key="PosHeaderBackgroundBrush" Color="{StaticResource PosColorHeader}" />
    <SolidColorBrush x:Key="PosHeaderForegroundBrush" Color="{StaticResource PosColorPrimaryDark}" />
    <SolidColorBrush x:Key="PosHeaderMutedForegroundBrush" Color="{StaticResource PosColorMutedText}" />
    <SolidColorBrush x:Key="PosFooterBackgroundBrush" Color="{StaticResource PosColorFooter}" />
    <SolidColorBrush x:Key="PosAccentForegroundBrush" Color="{StaticResource PosColorAccent}" />

    <FontFamily x:Key="PosFontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="PosFontSizeBody">14</sys:Double>
    <sys:Double x:Key="PosFontSizeSmall">12</sys:Double>
    <sys:Double x:Key="PosFontSizeTitle">22</sys:Double>
    <sys:Double x:Key="PosFontSizeAmount">32</sys:Double>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="FontSize" Value="{StaticResource PosFontSizeBody}" />
    </Style>

    <Style x:Key="PosTitleTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="FontSize" Value="{StaticResource PosFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PosCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="PosPillBaseStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PosStatusPillStyle" TargetType="Border" BasedOn="{StaticResource PosPillBaseStyle}">
        <Setter Property="Background" Value="#FFE7F7EF" />
    </Style>

    <Style x:Key="PosWarningPillStyle" TargetType="Border" BasedOn="{StaticResource PosPillBaseStyle}">
        <Setter Property="Background" Value="#FFFFF1D6" />
    </Style>

    <Style x:Key="PosPriceSourceBadgeStyle" TargetType="Border" BasedOn="{StaticResource PosPillBaseStyle}">
        <Setter Property="Background" Value="#FFE8F0FE" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <Style x:Key="PosButtonBaseStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource PosFontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.04" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.04" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PosButtonBaseStyle}">
        <Setter Property="Background" Value="{StaticResource PosPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="PosBlueGradientButtonStyle" TargetType="Button" BasedOn="{StaticResource PosButtonBaseStyle}">
        <Setter Property="BorderBrush" Value="#FF0046B2" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0088FF" Offset="0" />
                    <GradientStop Color="#FF0056D2" Offset="0.55" />
                    <GradientStop Color="#FF003C9A" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PosButtonBaseStyle}">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PosPrimaryDarkBrush}" />
    </Style>

    <Style x:Key="PosSearchSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource PosButtonBaseStyle}">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="PosDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PosDangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosDangerBrush}" />
    </Style>

    <Style x:Key="PosNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Background" Value="White" />
    </Style>

    <Style x:Key="PosActionTileButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="Margin" Value="6" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PosPaymentMethodButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="PosSearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PosAmountTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource PosSearchTextBoxStyle}">
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PosSearchResultListStyle" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PosCartDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="RowHeight" Value="44" />
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource PosFontSizeBody}" />
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FFF8FAFD" />
                    <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
                    <Setter Property="FontSize" Value="{StaticResource PosFontSizeSmall}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFF0F0F2" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFE2E2E6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFFFE0E0" />
                <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PosShellNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFF0F0F2" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFE2E2E6" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosIconTileButtonStyle" TargetType="Button" BasedOn="{StaticResource PosButtonBaseStyle}">
        <Setter Property="MinHeight" Value="78" />
        <Setter Property="Margin" Value="6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.14" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosQuickAmountButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PosAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Black" />
    </Style>

    <Style x:Key="PosSyncBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFF3F3F7" />
        <Setter Property="BorderBrush" Value="#FFD9DCE5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PosStitchTileLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Margin" Value="8,0,0,0" />
    </Style>

    <Style x:Key="PosStitchFunctionButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Background" Value="#FFE7E8EB" />
        <Setter Property="BorderBrush" Value="#FFE7E8EB" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="PosStitchDiscountButtonStyle" TargetType="Button" BasedOn="{StaticResource PosStitchFunctionButtonStyle}">
        <Setter Property="Background" Value="#FFFFE9D2" />
        <Setter Property="BorderBrush" Value="#FFFFE9D2" />
    </Style>

    <Style x:Key="PosStitchCheckoutButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPrimaryButtonStyle}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="PosStitchNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="Margin" Value="3" />
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#FFE2E2E6" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Black" />
    </Style>

    <Style x:Key="PosStitchClearNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PosStitchNumberButtonStyle}">
        <Setter Property="Background" Value="#FFFFDAD6" />
        <Setter Property="BorderBrush" Value="#FFFFDAD6" />
        <Setter Property="Foreground" Value="#FF93000A" />
    </Style>

    <Style x:Key="PosStitchQuickButtonStyle" TargetType="Button" BasedOn="{StaticResource PosStitchNumberButtonStyle}">
        <Setter Property="Background" Value="#FFFFDCC2" />
        <Setter Property="BorderBrush" Value="#FFFFDCC2" />
        <Setter Property="Foreground" Value="#FF2E1500" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="PosMainNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PosStitchNumberButtonStyle}">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#191C1E" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Template">
      <Setter.Value>
          <ControlTemplate TargetType="Button">
              <Border
                  x:Name="RootBorder"
                  Padding="4"
                  Background="{TemplateBinding Background}"
                  BorderBrush="#1F000000"
                  BorderThickness="1"
                  CornerRadius="12"
                  RenderTransformOrigin="0.5,0.5">
                  <Border.RenderTransform>
                      <ScaleTransform ScaleX="1" ScaleY="1" />
                  </Border.RenderTransform>
                  <Border.Effect>
                      <DropShadowEffect
                          BlurRadius="4"
                          Opacity="0.1"
                          ShadowDepth="1" />
                  </Border.Effect>
                  <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FontSize="{TemplateBinding FontSize}"
                      FontWeight="{TemplateBinding FontWeight}"
                      Foreground="{TemplateBinding Foreground}"
                      Text="{TemplateBinding Content}" />
              </Border>
              <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="RootBorder" Property="Background" Value="#E8F0FE" />
                      <Setter TargetName="RootBorder" Property="BorderBrush" Value="#330056D2" />
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="RootBorder" Property="RenderTransform">
                          <Setter.Value>
                              <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                          </Setter.Value>
                      </Setter>
                      <Setter TargetName="RootBorder" Property="Background" Value="#D6E4FA" />
                  </Trigger>
              </ControlTemplate.Triggers>
          </ControlTemplate>
      </Setter.Value>
  </Setter>
    </Style>

    <Style x:Key="PosMainClearNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PosMainNumberButtonStyle}">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#1F000000" />
        <Setter Property="Foreground" Value="#FF93000A" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="PosMainQuickButtonStyle" TargetType="Button" BasedOn="{StaticResource PosMainNumberButtonStyle}">
        <Setter Property="Background" Value="#FF8F00" />
        <Setter Property="BorderBrush" Value="#1F000000" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="RootBorder"
                        Padding="4"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#1F000000"
                        BorderThickness="1"
                        CornerRadius="12"
                        RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="6"
                                Opacity="0.15"
                                ShadowDepth="2" />
                        </Border.Effect>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="#E68200" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="RootBorder" Property="Background" Value="#CC7400" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosMainSwitchButtonStyle" TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="FontFamily" Value="{StaticResource PosFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Root"
                            Background="#FFE8F0FE"
                            BorderBrush="#FFD4E2FF"
                            BorderThickness="1"
                            CornerRadius="12"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,4,0"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="Wrap" />
                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="32"
                                    Height="18"
                                    Background="#FFC3C6D6"
                                    CornerRadius="9"
                                    VerticalAlignment="Center">
                                <Border x:Name="SwitchThumb"
                                        Width="14"
                                        Height="14"
                                        Margin="2"
                                        Background="White"
                                        CornerRadius="7"
                                        HorizontalAlignment="Left" />
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PosPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFDCEAFF" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PosPrimaryBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PosPrimaryBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#80FFFFFF" />
                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosNoBarcodeButtonStyle" TargetType="Button" BasedOn="{StaticResource PosBlueGradientButtonStyle}">
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="PosStitchActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
        <Setter Property="Height" Value="78" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="7" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PosStitchExitButtonStyle" TargetType="Button" BasedOn="{StaticResource PosStitchActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PosDangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="PosStitchActionIconCircleStyle" TargetType="Border">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background" Value="#FFDAE2FF" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PosStitchDangerIconCircleStyle" TargetType="Border" BasedOn="{StaticResource PosStitchActionIconCircleStyle}">
        <Setter Property="Background" Value="#FFFFDAD6" />
    </Style>

    <Style x:Key="PosStitchWarmIconCircleStyle" TargetType="Border" BasedOn="{StaticResource PosStitchActionIconCircleStyle}">
        <Setter Property="Background" Value="#FFFFDCC2" />
    </Style>

    <Style x:Key="PosStitchExitIconCircleStyle" TargetType="Border" BasedOn="{StaticResource PosStitchActionIconCircleStyle}">
        <Setter Property="Background" Value="#33FFFFFF" />
    </Style>
</ResourceDictionary>
