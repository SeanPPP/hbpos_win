<Window x:Class="Hbpos.Client.Wpf.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource PosFontFamily}">
    <Grid Background="Transparent" Margin="10">
        <Border Background="White"
                BorderBrush="#FFE3E7EF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="32">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="82"
                        Height="82"
                        Background="#FFE8F0FE"
                        BorderBrush="#FFD3E2FF"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="13"
                        HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/AppIcon.ico"
                           Stretch="Uniform" />
                </Border>
                <TextBlock Text="HB POS"
                           Margin="0,20,0,0"
                           FontSize="28"
                           FontWeight="Black"
                           Foreground="#FF1E293B"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Starting point of sale"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#FF64748B"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         Height="5"
                         Margin="48,20,48,0"
                         IsIndeterminate="True"
                         Foreground="#FF2563EB"
                         Background="#FFE2E8F0"
                         BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Window>
